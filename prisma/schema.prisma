model Form {
  id                        Int      @id @default(autoincrement())
  user_id                   Int
  name                      String
  description               String?
  max_submissions_total     Int?
  submission_limit_per_user Int?
  validate                  Boolean @default(false)
  fields_schema             String[]
  config_context            Json?
  ttl_interval              String? // PostgreSQL INTERVAL handled as string in Prisma
  is_active                 Boolean  @default(true)
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt @default(now())

  user        User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id            Int      @id @default(autoincrement())
  form_id       Int
  response_data Json
  status        Int      @default(-1) // -1: NOT_MATCHED, 0: MATCHED, 1: STRONGLY_MATCHED
  created_at    DateTime @default(now())

  form Form @relation(fields: [form_id], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}
